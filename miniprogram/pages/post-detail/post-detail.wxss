/* 帖子详情页面整体样式 - QQ空间风格 */
.post-detail-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/* 帖子内容卡片 */
.post-detail {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* 帖子头部 */
.post-header {
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.author-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.author-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #666;
}

.post-category {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 帖子标题 */
.post-title {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.post-title text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

/* 帖子内容 */
.post-content {
  padding: 30rpx;
}

.post-content text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 30rpx;
}

/* 帖子图片 */
.post-images {
  margin: 30rpx 0;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.image-item image:hover {
  transform: scale(1.05);
}

/* 帖子统计 */
.post-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.post-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.action-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 20rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.action-button:hover {
  background: #f5f5f5;
  transform: translateY(-2rpx);
}

.action-button.liked {
  color: #ff4757;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 评论区域样式优化 - QQ空间风格 */
.comments-section {
  background: #fff;
  margin-top: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.comments-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.comments-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.comments-list {
  padding: 0;
}

.comment-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background: #fff;
  transition: background-color 0.3s ease;
}

.comment-item:hover {
  background: #fafafa;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.comment-author {
  margin-left: 20rpx;
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  margin: 20rpx 0;
  padding-left: 80rpx;
}

.comment-content text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-left: 80rpx;
  margin-top: 20rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  cursor: pointer;
  transition: background-color 0.2s;
}

.action-item:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.action-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1;
}

.action-text.liked {
  color: #0052d9;
  font-weight: 500;
}

.comment-stats {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 24rpx;
}

.comment-stats text {
  margin-left: 8rpx;
}

.empty-comments {
  padding: 80rpx 30rpx;
  text-align: center;
}

.load-more, .no-more {
  padding: 30rpx;
  text-align: center;
}

.no-more text {
  color: #999;
  font-size: 24rpx;
}

/* 评论输入框 */
.comment-input-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.comment-input-container {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.input-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .post-detail,
  .comments-section {
    margin: 10rpx;
    padding: 24rpx;
  }
  
  .post-images .image-item {
    width: calc(50% - 8rpx);
    height: 160rpx;
  }
  
  .post-actions {
    flex-direction: column;
    gap: 12rpx;
  }
}
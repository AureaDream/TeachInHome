<view class="my-posts-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">我的帖子</text>
    <text class="post-count">共 {{posts.length}} 篇</text>
  </view>
  
  <!-- 加载状态 -->
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." />
  
  <!-- 帖子列表 -->
  <view wx:if="{{!loading}}" class="posts-list">
    <view 
      wx:for="{{posts}}" 
      wx:key="id" 
      class="post-item"
      bindtap="onPostTap"
      data-post="{{item}}"
    >
      <!-- 帖子头部 -->
      <view class="post-header">
        <view class="author-info">
          <t-avatar src="{{item.author.avatar}}" size="60rpx" />
          <view class="author-details">
            <text class="author-name">{{item.author.name}}</text>
            <text class="post-time">{{item.createTime}}</text>
          </view>
        </view>
        <view class="post-category">
          <t-tag theme="{{getCategoryTheme(item.category)}}" size="small">
            {{getCategoryName(item.category)}}
          </t-tag>
        </view>
      </view>
      
      <!-- 帖子内容 -->
      <view class="post-content">
        <view class="post-title">
          <text>{{item.title}}</text>
        </view>
        <view class="post-summary">
          <text>{{item.summary}}</text>
        </view>
      </view>
      
      <!-- 帖子图片 -->
      <view wx:if="{{item.images.length > 0}}" class="post-images">
        <view 
          wx:for="{{item.images}}" 
          wx:for-item="image" 
          wx:for-index="imageIndex" 
          wx:key="imageIndex" 
          class="image-item"
          bindtap="onImageTap"
          data-images="{{item.images}}"
          data-current="{{image}}"
        >
          <image src="{{image}}" mode="aspectFill" />
        </view>
      </view>
      
      <!-- 帖子统计 -->
      <view class="post-stats">
        <view class="stat-item">
          <t-icon name="thumb-up" size="28rpx" />
          <text>{{item.likeCount}}</text>
        </view>
        <view class="stat-item">
          <t-icon name="chat" size="28rpx" />
          <text>{{item.commentCount}}</text>
        </view>
        <view class="stat-item">
          <t-icon name="browse" size="28rpx" />
          <text>{{item.viewCount}}</text>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="post-actions">
        <t-button 
          theme="primary" 
          variant="outline" 
          size="small"
          bindtap="onJumpToPost"
          data-post="{{item}}"
        >
          跳转
        </t-button>
        
        <t-button 
          theme="danger" 
          variant="outline" 
          size="small"
          bindtap="onDeletePost"
          data-post="{{item}}"
        >
          删除
        </t-button>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view wx:if="{{posts.length === 0 && !loading}}" class="empty-state">
    <t-empty 
      icon="edit" 
      description="还没有发布过帖子"
    >
      <t-button 
        theme="primary" 
        size="small"
        bindtap="onGoToForum"
      >
        去发帖
      </t-button>
    </t-empty>
  </view>
  
  <!-- 加载更多 -->
  <view wx:if="{{hasMore && posts.length > 0}}" class="load-more">
    <t-button 
      theme="default" 
      variant="text" 
      size="small"
      loading="{{loadingMore}}"
      bindtap="loadMore"
    >
      {{loadingMore ? '加载中...' : '加载更多'}}
    </t-button>
  </view>
  
  <view wx:if="{{!hasMore && posts.length > 0}}" class="no-more">
    <text>没有更多帖子了</text>
  </view>
</view>

<!-- Toast 组件 -->
<t-toast id="t-toast" />
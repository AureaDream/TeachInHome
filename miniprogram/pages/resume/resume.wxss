.resume-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航 */
.resume-nav {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

/* 表单部分 */
.form-section {
  flex: 1;
  overflow: hidden;
}

.form-scroll {
  height: 100%;
  padding-bottom: 200rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.group-title {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.group-title text {
  margin-left: 12rpx;
}

/* 科目标签 */
.subject-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 0;
}

.subject-tags .t-tag {
  margin: 0;
}

/* 表单操作 */
.form-actions {
  padding: 40rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.form-actions .t-button {
  margin-bottom: 20rpx;
}

.form-actions .t-button:last-child {
  margin-bottom: 0;
}

/* 预览部分 */
.preview-section {
  flex: 1;
  overflow: hidden;
}

.preview-scroll {
  height: 100%;
  padding-bottom: 200rpx;
}

.resume-preview {
  background: #fff;
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 简历头部 */
.resume-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #0052d9;
}

.resume-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.resume-subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 简历章节 */
.resume-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #0052d9;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-item .label {
  font-size: 28rpx;
  color: #666;
  min-width: 120rpx;
}

.info-item .value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 内容项 */
.content-item {
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.content-item:last-child {
  margin-bottom: 0;
}

.content-item .label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  display: inline-block;
  min-width: 140rpx;
}

.content-item .value {
  font-size: 28rpx;
  color: #333;
}

/* 预览操作 */
.preview-actions {
  padding: 40rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.preview-actions .t-button {
  margin-bottom: 20rpx;
}

.preview-actions .t-button:last-child {
  margin-bottom: 0;
}

/* TDesign组件样式覆盖 */
.t-cell-group {
  margin: 0 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.t-cell {
  padding: 24rpx 30rpx;
}

.t-cell__title {
  font-size: 28rpx;
  color: #333;
}

.t-cell__note {
  flex: 1;
  margin-left: 20rpx;
}

.t-input {
  text-align: right;
}

.t-textarea {
  width: 100%;
  min-height: 120rpx;
}

.t-picker {
  text-align: right;
  color: #666;
}

.t-radio-group {
  display: flex;
  gap: 40rpx;
}

.t-tag {
  margin: 4rpx;
}

.t-tabs__nav {
  background: #fff;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .info-grid {
    grid-template-columns: 1fr;
  }
  
  .resume-preview {
    margin: 10rpx;
    padding: 30rpx;
  }
  
  .form-actions,
  .preview-actions {
    padding: 30rpx;
  }
}
<view class="forum-container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <t-search 
      model:value="{{searchValue}}"
      placeholder="搜索帖子内容"
      bind:submit="onSearch"
      bind:clear="onSearchClear"
    />
  </view>

  <!-- 分类标签 -->
  <view class="category-tabs">
    <t-tabs 
      value="{{activeCategory}}"
      bind:change="onCategoryChange"
      space-evenly
    >
      <t-tab-panel label="全部" value="all" />
      <t-tab-panel label="求助" value="help" />
      <t-tab-panel label="分享" value="share" />
      <t-tab-panel label="讨论" value="discuss" />
      <t-tab-panel label="资源" value="resource" />
    </t-tabs>
  </view>

  <!-- 发帖按钮 -->
  <view class="post-button">
    <t-button 
      theme="primary" 
      size="large"
      icon="add"
      bind:tap="onCreatePost"
    >
      发布帖子
    </t-button>
  </view>

  <!-- 帖子列表 -->
  <scroll-view 
    class="post-list"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bind:refresherrefresh="onRefresh"
    bind:scrolltolower="onLoadMore"
  >
    <!-- 加载状态 -->
    <view wx:if="{{loading && posts.length === 0}}" class="loading-container">
      <t-loading theme="circular" size="40rpx" text="加载中..." />
    </view>

    <!-- 帖子列表 -->
    <view wx:else class="posts-container">
      <view 
        wx:for="{{posts}}"
        wx:key="id"
        class="post-item"
        bind:tap="onPostTap"
        data-post="{{item}}"
      >
        <!-- 帖子头部 -->
        <view class="post-header">
          <view class="user-info">
            <image class="avatar" src="{{item.author.avatar}}" mode="aspectFill" />
            <view class="user-details">
              <text class="username">{{item.author.name}}</text>
              <text class="post-time">{{item.createTime}}</text>
            </view>
          </view>
          <view class="category-tag">
            <t-tag 
              theme="{{getCategoryTheme(item.category)}}"
              size="small"
            >
              {{getCategoryName(item.category)}}
            </t-tag>
          </view>
        </view>

        <!-- 帖子内容 -->
        <view class="post-content">
          <text class="post-title">{{item.title}}</text>
          <text class="post-summary">{{item.summary}}</text>
          
          <!-- 图片预览 -->
          <view wx:if="{{item.images && item.images.length > 0}}" class="post-images">
            <image 
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:key="*this"
              class="post-image"
              src="{{img}}"
              mode="aspectFill"
              bind:tap="onImageTap"
              data-images="{{item.images}}"
              data-current="{{img}}"
            />
          </view>
        </view>

        <!-- 帖子统计 -->
        <view class="post-stats">
          <view class="stat-item">
            <t-icon name="thumb-up" size="28rpx" color="{{item.isLiked ? '#0052d9' : '#999'}}" />
            <text class="stat-text {{item.isLiked ? 'liked' : ''}}">{{item.likeCount}}</text>
          </view>
          <view class="stat-item">
            <t-icon name="chat" size="28rpx" color="#999" />
            <text class="stat-text">{{item.commentCount}}</text>
          </view>
          <view class="stat-item">
            <t-icon name="view" size="28rpx" color="#999" />
            <text class="stat-text">{{item.viewCount}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="post-actions">
          <t-button 
            size="small"
            variant="text"
            icon="thumb-up"
            bind:tap="onLikePost"
            data-post="{{item}}"
            class="{{item.isLiked ? 'liked' : ''}}"
          >
            {{item.isLiked ? '已赞' : '点赞'}}
          </t-button>
          <t-button 
            size="small"
            variant="text"
            icon="chat"
            bind:tap="onCommentPost"
            data-post="{{item}}"
          >
            评论
          </t-button>
          <t-button 
            size="small"
            variant="text"
            icon="share"
            bind:tap="onSharePost"
            data-post="{{item}}"
          >
            分享
          </t-button>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!loading && posts.length === 0}}" class="empty-container">
        <t-empty 
          icon="chat"
          description="暂无帖子，快来发布第一个帖子吧！"
        >
          <t-button 
            slot="action"
            theme="primary"
            size="small"
            bind:tap="onCreatePost"
          >
            发布帖子
          </t-button>
        </t-empty>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more">
        <t-loading wx:if="{{loadingMore}}" theme="circular" size="32rpx" text="加载中..." />
        <text wx:else class="load-more-text">上拉加载更多</text>
      </view>
      
      <!-- 没有更多 -->
      <view wx:elif="{{posts.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多帖子了</text>
      </view>
    </view>
  </scroll-view>

  <!-- 发帖弹窗 -->
  <t-dialog
    visible="{{showCreateDialog}}"
    title="发布帖子"
    confirm-btn="发布"
    cancel-btn="取消"
    bind:confirm="onConfirmCreate"
    bind:cancel="onCancelCreate"
  >
    <view class="create-form">
      <view class="form-item">
        <text class="form-label">分类</text>
        <t-picker 
          value="{{newPost.category}}"
          options="{{categoryOptions}}"
          bind:change="onNewPostCategoryChange"
        >
          <t-cell 
            title="选择分类"
            note="{{getCategoryName(newPost.category)}}"
            arrow
          />
        </t-picker>
      </view>
      
      <view class="form-item">
        <text class="form-label">标题</text>
        <t-input 
          model:value="{{newPost.title}}"
          placeholder="请输入帖子标题"
          maxlength="50"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">内容</text>
        <t-textarea 
          model:value="{{newPost.content}}"
          placeholder="请输入帖子内容"
          maxlength="500"
          autosize
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">图片</text>
        <view class="image-upload">
          <view 
            wx:for="{{newPost.images}}"
            wx:key="*this"
            class="upload-image"
          >
            <image src="{{item}}" mode="aspectFill" />
            <view 
              class="delete-btn"
              bind:tap="onDeleteImage"
              data-index="{{index}}"
            >
              <t-icon name="close" size="24rpx" color="#fff" />
            </view>
          </view>
          
          <view 
            wx:if="{{newPost.images.length < 3}}"
            class="upload-btn"
            bind:tap="onUploadImage"
          >
            <t-icon name="add" size="48rpx" color="#999" />
            <text class="upload-text">添加图片</text>
          </view>
        </view>
      </view>
    </view>
  </t-dialog>

  <!-- Toast提示 -->
  <t-toast id="t-toast" />
</view>
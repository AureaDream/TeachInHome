.orders-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

/* 筛选标签 */
.filter-tabs {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

/* 定位栏样式 */
.location-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #e5e5e5;
}

.location-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.location-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
}

/* 筛选器 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.filter-item text {
  margin-top: 8rpx;
}

.filter-value {
  color: #0052d9 !important;
  font-size: 20rpx !important;
  margin-top: 4rpx !important;
}

/* 订单列表 */
.orders-list {
  padding: 20rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #666;
}

.loading text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

.empty {
  padding: 100rpx 0;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.order-info {
  flex: 1;
}

.order-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.order-subtitle {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  margin-left: 20rpx;
}

/* 订单内容 */
.order-content {
  margin-bottom: 20rpx;
}

.content-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  position: relative;
}

.content-row:last-child {
  margin-bottom: 0;
}

.content-text {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #666;
  flex: 1;
  line-height: 1.4;
}

.distance-text {
  margin-left: auto;
  font-size: 24rpx;
  color: #0052d9;
  font-weight: 500;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.salary {
  display: flex;
  align-items: baseline;
}

.salary-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #e34d59;
}

.salary-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.order-actions {
  display: flex;
  gap: 20rpx;
}

/* 加载更多 */
.load-more {
  padding: 40rpx 20rpx;
  text-align: center;
}

/* 弹窗内容 */
.subject-list,
.distance-list,
.salary-list {
  padding: 20rpx 0;
  max-height: 600rpx;
  overflow-y: auto;
}

.subject-list .t-radio,
.distance-list .t-radio,
.salary-list .t-radio {
  margin-bottom: 20rpx;
}

/* TDesign组件样式覆盖 */
.t-tabs__nav {
  background: #fff;
}

.t-tab-panel {
  padding: 20rpx 0;
}

.t-search {
  background: #f8f8f8;
}

.t-button--size-small {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.t-tag--theme-success {
  background-color: rgba(0, 168, 112, 0.1);
  color: #00a870;
}

.t-tag--theme-warning {
  background-color: rgba(237, 123, 47, 0.1);
  color: #ed7b2f;
}
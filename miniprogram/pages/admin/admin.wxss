.admin-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30rpx;
}

/* 顶部标签页 */
.custom-tabs {
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

/* 发布订单按钮栏 */
.publish-order-bar {
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.publish-order-bar .t-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 筛选栏 */
.filter-bar {
  background-color: #fff;
  margin-bottom: 20rpx;
}

/* 列表容器 */
.list-container {
  position: relative;
  min-height: 400rpx;
}

/* 加载状态 */
.loading-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 用户列表 */
.user-list {
  padding: 0 20rpx;
}

.user-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.user-avatar-container {
  position: relative;
  margin-right: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.user-role {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  color: #fff;
}

.admin-role {
  background-color: #ff4d4f;
}

.user-role {
  background-color: #0052d9;
}

.user-info {
  flex: 1;
  overflow: hidden;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.user-stats {
  display: flex;
  font-size: 24rpx;
  color: #666;
}

.stat-item {
  margin-right: 20rpx;
}

.user-actions {
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  height: 100rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 10rpx;
}

.order-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 20rpx;
}

.info-item:last-child {
  margin-right: 0;
}

.info-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
  min-width: 60rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.info-value.price {
  font-weight: bold;
  color: #ff4d4f;
}

.order-description {
  background-color: #f8f9fa;
  border-radius: 8rpx;
  padding: 12rpx;
  margin-bottom: 16rpx;
}

.description-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.order-publisher {
  font-size: 24rpx;
  color: #666;
}

.order-time {
  font-size: 22rpx;
  color: #999;
}

.order-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999;
}

.order-actions {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.order-id {
  font-size: 26rpx;
  color: #666;
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-subject {
  display: flex;
  align-items: center;
}

.education-stage {
  font-size: 28rpx;
  color: #333;
  margin-left: 10rpx;
}

.order-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
}

/* 帖子列表 */
.post-list {
  padding: 0 20rpx;
}

.post-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-content {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-footer {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.post-author {
  margin-bottom: 8rpx;
}

.post-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.post-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
}

/* 系统设置 */
.settings-container {
  padding: 20rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 弹窗内容 */
.dialog-content {
  padding: 20rpx 0;
}

/* 发布订单表单样式 */
.publish-order-form {
  padding: 20rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.publish-order-form .form-item {
  margin: 24rpx 0;
}

.publish-order-form .form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.publish-order-form .t-input,
.publish-order-form .t-textarea {
  margin-bottom: 0;
}

.publish-order-form .t-picker {
  width: 100%;
}

/* 通用表单样式 */
.form-item {
  margin: 30rpx 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

/* TDesign组件样式覆盖 */
.t-cell-group__title {
  font-size: 28rpx;
  color: #999;
  padding: 24rpx 30rpx 12rpx;
}

.t-input,
.t-textarea {
  margin-bottom: 20rpx;
}

.t-radio-group {
  display: flex;
  flex-wrap: wrap;
}

.t-radio {
  margin-right: 30rpx;
  margin-bottom: 10rpx;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .user-item,
  .order-item,
  .post-item {
    padding: 15rpx;
  }
  
  .user-avatar {
    width: 80rpx;
    height: 80rpx;
  }
  
  .user-name {
    font-size: 28rpx;
  }
  
  .post-title {
    font-size: 28rpx;
  }
}
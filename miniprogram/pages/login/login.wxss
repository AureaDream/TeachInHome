.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 100rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 350rpx;
}

.logo {
  margin-bottom: 40rpx;
}

.logo-img {
  width: 200rpx;
  height: auto;
  border-radius: 8rpx;
  display: block;
  margin: 0 auto;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录表单 */
.login-form {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.wechat-login {
  margin: 0;
}

.divider {
  margin: 40rpx 0;
}

.phone-login {
  margin-bottom: 60rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.login-btn {
  margin-top: 40rpx;
}

/* 用户协议 */
.agreement {
  margin-top: auto;
  padding-top: 40rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  line-height: 1.5;
}

.link {
  color: #fff;
  text-decoration: underline;
}

/* 管理员入口 */
.admin-entry {
  position: fixed;
  top: 100rpx;
  right: 40rpx;
  padding: 20rpx;
}

.admin-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 管理员自定义弹窗 */
.admin-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.admin-modal {
  background: #fff;
  border-radius: 16rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.admin-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.admin-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.admin-modal-close {
  color: #999;
  padding: 10rpx;
}

.admin-modal-content {
  padding: 40rpx;
}

.admin-input-group {
  margin-bottom: 30rpx;
}

.admin-input-group:last-of-type {
  margin-bottom: 20rpx;
}

.admin-input {
  width: 100%;
}

.admin-tips {
  text-align: center;
  margin-top: 20rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.admin-modal-footer {
  display: flex;
  padding: 20rpx 40rpx 40rpx;
  gap: 20rpx;
}

.admin-cancel-btn {
  flex: 1;
}

.admin-confirm-btn {
  flex: 1;
}

/* TDesign组件样式覆盖 */
.t-input {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
}

.t-button--theme-primary {
  background: #0052d9;
  border-color: #0052d9;
}

.t-button--theme-outline {
  background: transparent;
  border-color: #0052d9;
  color: #0052d9;
}

.t-divider__content {
  color: rgba(255, 255, 255, 0.8);
}

.t-divider__line {
  border-color: rgba(255, 255, 255, 0.3);
}
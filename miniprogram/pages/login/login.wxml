<view class="login-container">
  <!-- 顶部Logo区域 -->
  <view class="logo-section">
    <view class="logo">
      <t-icon name="education" size="80rpx" color="#0052d9" />
    </view>
    <view class="app-name">家教接单平台</view>
    <view class="app-desc">专业家教，值得信赖</view>
  </view>

  <!-- 登录表单区域 -->
  <view class="login-form">
    <!-- 微信一键登录 -->
    <view class="wechat-login">
      <t-button 
        theme="primary" 
        size="large" 
        block
        icon="wechat"
        bind:tap="onWechatLogin"
        loading="{{wechatLoading}}"
      >
        微信一键登录
      </t-button>
    </view>

    <!-- 分割线 -->
    <view class="divider">
      <t-divider>或</t-divider>
    </view>

    <!-- 手机号登录 -->
    <view class="phone-login">
      <view class="input-group">
        <t-input
          placeholder="请输入手机号"
          type="number"
          maxlength="11"
          value="{{phone}}"
          bind:change="onPhoneChange"
          prefix-icon="mobile"
        />
      </view>
      
      <view class="input-group">
        <t-input
          placeholder="请输入验证码"
          type="number"
          maxlength="6"
          value="{{code}}"
          bind:change="onCodeChange"
          prefix-icon="secured"
        >
          <view slot="suffix">
            <t-button
              theme="outline"
              size="small"
              bind:tap="onSendCode"
              disabled="{{codeDisabled}}"
            >
              {{codeText}}
            </t-button>
          </view>
        </t-input>
      </view>

      <view class="login-btn">
        <t-button 
          theme="primary" 
          size="large" 
          block
          bind:tap="onPhoneLogin"
          loading="{{phoneLoading}}"
          disabled="{{!phone || !code}}"
        >
          登录
        </t-button>
      </view>
    </view>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <view class="agreement-text">
      登录即表示同意
      <text class="link" bind:tap="onShowAgreement">《用户协议》</text>
      和
      <text class="link" bind:tap="onShowPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="admin-entry" bind:tap="onAdminEntry">
    <text class="admin-text">管理员入口</text>
  </view>
</view>

<!-- 管理员密码弹窗 -->
<t-dialog
  visible="{{showAdminDialog}}"
  title="管理员登录"
  confirm-btn="登录"
  cancel-btn="取消"
  bind:confirm="onAdminLogin"
  bind:cancel="onCloseAdminDialog"
>
  <view class="admin-dialog">
    <t-input
      placeholder="请输入管理员密码"
      type="password"
      value="{{adminPassword}}"
      bind:change="onAdminPasswordChange"
    />
  </view>
</t-dialog>

<!-- Toast提示 -->
<t-toast id="t-toast" />
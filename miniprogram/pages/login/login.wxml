<view class="login-container">
  <!-- 顶部Logo区域 -->
  <view class="logo-section">
    <view class="logo">
      <t-icon name="education" size="80rpx" color="#0052d9" />
    </view>
    <view class="app-name">家教接单平台</view>
    <view class="app-desc">专业家教，值得信赖</view>
  </view>

  <!-- 登录表单区域 -->
  <view class="login-form">
    <!-- 微信一键登录 -->
    <view class="wechat-login">
      <t-button 
        theme="primary" 
        size="large" 
        block
        icon="wechat"
        bind:tap="onWechatLogin"
        loading="{{wechatLoading}}"
      >
        微信一键登录
      </t-button>
    </view>

    <!-- 分割线 -->
    <view class="divider">
      <t-divider>或</t-divider>
    </view>

    <!-- 手机号登录 -->
    <view class="phone-login">
      <view class="input-group">
        <t-input
          placeholder="请输入手机号"
          type="number"
          maxlength="11"
          value="{{phone}}"
          bind:change="onPhoneChange"
          prefix-icon="mobile"
        />
      </view>
      
      <view class="input-group">
        <t-input
          placeholder="请输入验证码"
          type="number"
          maxlength="6"
          value="{{code}}"
          bind:change="onCodeChange"
          prefix-icon="secured"
        >
          <view slot="suffix">
            <t-button
              theme="outline"
              size="small"
              bind:tap="onSendCode"
              disabled="{{codeDisabled}}"
            >
              {{codeText}}
            </t-button>
          </view>
        </t-input>
      </view>

      <view class="login-btn">
        <t-button 
          theme="primary" 
          size="large" 
          block
          bind:tap="onPhoneLogin"
          loading="{{phoneLoading}}"
          disabled="{{!phone || !code}}"
        >
          登录
        </t-button>
      </view>
    </view>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <view class="agreement-text">
      登录即表示同意
      <text class="link" bind:tap="onShowAgreement">《用户协议》</text>
      和
      <text class="link" bind:tap="onShowPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="admin-entry" bind:tap="onAdminEntry">
    <text class="admin-text">管理员入口</text>
  </view>
</view>

<!-- 管理员登录弹窗遮罩 -->
<view class="admin-modal-mask" wx:if="{{showAdminDialog}}" bind:tap="onCloseAdminDialog">
  <view class="admin-modal" catch:tap="stopPropagation">
    <!-- 弹窗标题 -->
    <view class="admin-modal-header">
      <text class="admin-modal-title">管理员登录</text>
      <t-icon name="close" size="40rpx" class="admin-modal-close" bind:tap="onCloseAdminDialog" />
    </view>
    
    <!-- 弹窗内容 -->
    <view class="admin-modal-content">
      <view class="admin-input-group">
        <t-input
          placeholder="请输入管理员用户名"
          value="{{adminUsername}}"
          bind:change="onAdminUsernameChange"
          class="admin-input"
          disabled="{{adminLoading}}"
          prefix-icon="user"
        />
      </view>
      <view class="admin-input-group">
        <t-input
          placeholder="请输入管理员密码"
          type="password"
          value="{{adminPassword}}"
          bind:change="onAdminPasswordChange"
          class="admin-input"
          disabled="{{adminLoading}}"
          prefix-icon="lock-on"
        />
      </view>
      <view class="admin-tips">
        <text class="tips-text">请使用管理员账号登录后台管理系统</text>
      </view>
    </view>
    
    <!-- 弹窗按钮 -->
    <view class="admin-modal-footer">
      <t-button
        theme="outline"
        size="medium"
        bind:tap="onCloseAdminDialog"
        disabled="{{adminLoading}}"
        class="admin-cancel-btn"
      >
        取消
      </t-button>
      <t-button
        theme="primary"
        size="medium"
        bind:tap="onAdminLogin"
        loading="{{adminLoading}}"
        class="admin-confirm-btn"
      >
        {{adminLoading ? '登录中...' : '登录'}}
      </t-button>
    </view>
  </view>
</view>

<!-- Toast提示 -->
<t-toast id="t-toast" />
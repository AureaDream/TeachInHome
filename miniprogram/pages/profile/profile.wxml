<view class="profile-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <view class="avatar-container">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-default.svg'}}" mode="aspectFill" />
        <view class="edit-avatar-btn" bindtap="onEditAvatar">
          <t-icon name="edit" size="32rpx" color="#fff" />
        </view>
      </view>
      <view class="info-content">
        <view class="username-container">
          <text class="username">{{userInfo.nickName || '未登录'}}</text>
          <view class="edit-profile-btn" bindtap="onEditProfile">
            <t-icon name="edit" size="28rpx" color="#666" />
          </view>
        </view>
      </view>
    </view>
    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-value">{{stats.orderCount || 0}}</text>
        <text class="stat-label">订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.favoriteCount || 0}}</text>
        <text class="stat-label">收藏</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.postCount || 0}}</text>
        <text class="stat-label">帖子</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <t-cell-group title="我的订单">
      <t-cell title="我接受的订单" hover arrow url="/pages/my-orders/my-orders?type=accepted">
        <t-icon name="check-circle" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
      <t-cell title="我收藏的订单" hover arrow url="/pages/my-orders/my-orders?type=favorite">
        <t-icon name="heart" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
    </t-cell-group>

    <t-cell-group title="我的论坛">
      <t-cell title="我的帖子" hover arrow url="/pages/my-posts/my-posts">
        <t-icon name="chat" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
      <t-cell title="我的回复" hover arrow url="/pages/my-comments/my-comments">
        <t-icon name="chat-bubble" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
    </t-cell-group>

    <t-cell-group title="设置">
      <t-cell title="个人信息" hover arrow bind:tap="onEditProfile">
        <t-icon name="edit" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
      <t-cell title="消息通知" hover arrow bind:tap="onNotificationSettings">
        <t-icon name="notification" slot="left-icon" size="48rpx" color="#0052d9" />
        <t-badge count="{{unreadCount}}" slot="note" />
      </t-cell>
      <t-cell title="隐私设置" hover arrow bind:tap="onPrivacySettings">
        <t-icon name="lock" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
      <t-cell title="关于我们" hover arrow bind:tap="onAboutUs">
        <t-icon name="info-circle" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
      <t-cell title="联系客服" hover arrow bind:tap="onContactService">
        <t-icon name="service" slot="left-icon" size="48rpx" color="#0052d9" />
      </t-cell>
    </t-cell-group>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <t-button theme="danger" size="large" bind:tap="onLogout">退出登录</t-button>
  </view>

  <!-- 编辑个人信息弹窗 -->
  <t-dialog
    visible="{{showEditDialog}}"
    title="编辑个人信息"
    confirm-btn="{{ {content: '保存', variant: 'base', loading: false} }}"
    cancel-btn="{{ {content: '取消', variant: 'outline'} }}"
    bind:confirm="onConfirmEdit"
    bind:cancel="onCancelEdit"
    width="90%"
    z-index="11500"
    show-overlay="{{true}}"
    close-on-overlay-click="{{false}}"
  >
    <view class="edit-form" slot="content">
      <!-- 昵称输入 -->
      <view class="form-item">
        <view class="form-label-container">
          <text class="form-label required">昵称</text>
          <text class="form-tip">2-20个字符</text>
        </view>
        <t-input 
          class="form-input"
          value="{{editForm.nickName}}"
          placeholder="请输入昵称"
          maxlength="{{20}}"
          bind:change="onNickNameChange"
          bind:blur="onNickNameChange"
          bind:input="onNickNameChange"
          clearable="{{true}}"
          size="medium"
          align="left"
        />
      </view>
      
      <!-- 手机号输入 -->
      <view class="form-item">
        <view class="form-label-container">
          <text class="form-label">手机号</text>
          <text class="form-tip">选填，11位手机号</text>
        </view>
        <t-input 
          class="form-input"
          value="{{editForm.phone}}"
          placeholder="请输入手机号"
          type="number"
          maxlength="{{11}}"
          bind:change="onPhoneChange"
          bind:blur="onPhoneChange"
          bind:input="onPhoneChange"
          clearable="{{true}}"
          size="medium"
          align="left"
        />
      </view>
      
      <!-- 邮箱输入 -->
      <view class="form-item">
        <view class="form-label-container">
          <text class="form-label">邮箱</text>
          <text class="form-tip">选填，用于接收通知</text>
        </view>
        <t-input 
          class="form-input"
          value="{{editForm.email}}"
          placeholder="请输入邮箱地址"
          maxlength="{{50}}"
          bind:change="onEmailChange"
          bind:blur="onEmailChange"
          bind:input="onEmailChange"
          clearable="{{true}}"
          size="medium"
          align="left"
        />
      </view>
      
      <!-- 个人简介输入 -->
      <view class="form-item">
        <view class="form-label-container">
          <text class="form-label">个人简介</text>
          <text class="form-tip">选填，最多200字</text>
        </view>
        <t-textarea 
          class="form-textarea"
          value="{{editForm.bio}}"
          placeholder="请输入个人简介，介绍一下自己吧~"
          maxlength="{{200}}"
          autosize="{{true}}"
          bind:change="onBioChange"
          bind:blur="onBioChange"
          bind:input="onBioChange"
          indicator="{{true}}"
          bordered="{{true}}"
        />
      </view>
      
      <!-- 表单提示信息 -->
      <view class="form-notice">
        <t-icon name="info-circle" size="28rpx" color="#0052d9" />
        <text class="notice-text">个人信息将同步到云端，请确保信息真实有效</text>
      </view>
    </view>
  </t-dialog>

  <!-- 消息通知弹窗 -->
  <t-dialog
    visible="{{showNotificationDialog}}"
    title="消息通知"
    confirm-btn="确定"
    bind:confirm="onCloseNotificationDialog"
  >
    <view class="notification-list" slot="content">
      <view wx:if="{{notifications.length === 0}}" class="empty-notification">
        <text>暂无消息通知</text>
      </view>
      <view 
        wx:for="{{notifications}}"
        wx:key="id"
        class="notification-item"
      >
        <view class="notification-header">
          <text class="notification-title">{{item.title}}</text>
          <text class="notification-time">{{item.time}}</text>
        </view>
        <text class="notification-content">{{item.content}}</text>
      </view>
    </view>
  </t-dialog>

  <!-- 隐私设置弹窗 -->
  <t-dialog
    visible="{{showPrivacyDialog}}"
    title="隐私设置"
    confirm-btn="保存"
    cancel-btn="取消"
    bind:confirm="onConfirmPrivacy"
    bind:cancel="onCancelPrivacy"
  >
    <view class="privacy-form" slot="content">
      <t-cell title="公开个人信息" bordered="{{false}}">
        <t-switch slot="note" value="{{privacySettings.publicProfile}}" bind:change="onPrivacyChange" data-field="publicProfile" />
      </t-cell>
      <t-cell title="接收订单通知" bordered="{{false}}">
        <t-switch slot="note" value="{{privacySettings.orderNotification}}" bind:change="onPrivacyChange" data-field="orderNotification" />
      </t-cell>
      <t-cell title="接收论坛通知" bordered="{{false}}">
        <t-switch slot="note" value="{{privacySettings.forumNotification}}" bind:change="onPrivacyChange" data-field="forumNotification" />
      </t-cell>
    </view>
  </t-dialog>

  <!-- 关于我们弹窗 -->
  <t-dialog
    visible="{{showAboutDialog}}"
    title="关于我们"
    confirm-btn="确定"
    bind:confirm="onCloseAboutDialog"
  >
    <view class="about-content" slot="content">
      <image class="about-logo" src="/images/logo.png" mode="aspectFit" />
      <text class="about-title">家里教小程序</text>
      <text class="about-version">版本号: 1.0.0</text>
      <text class="about-desc">本应用致力于为学生和家教提供便捷的对接平台，帮助老师互相交流沟通，帮助家教找到合适的学生。</text>
      <view class="about-links">
        <text class="link" bind:tap="onOpenUserAgreement">用户协议</text>
        <text class="link-divider">|</text>
        <text class="link" bind:tap="onOpenPrivacyPolicy">隐私政策</text>
      </view>
    </view>
  </t-dialog>

  <!-- 联系客服弹窗 -->
  <t-dialog
    visible="{{showContactDialog}}"
    title="联系客服"
    confirm-btn="{{ {content: '复制微信号', variant: 'base'} }}"
    cancel-btn="{{ {content: '关闭', variant: 'outline'} }}"
    bind:confirm="onCopyWechatId"
    bind:cancel="onCloseContactDialog"
    width="80%"
  >
    <view class="contact-content" slot="content">
      <view class="contact-info">
        <view class="contact-item">
          <t-icon name="user" size="40rpx" color="#0052d9" />
          <view class="contact-text">
            <text class="contact-label">客服昵称</text>
            <text class="contact-value">{{customerService.nickname}}</text>
          </view>
        </view>
        <view class="contact-item">
          <t-icon name="logo-wechat" size="40rpx" color="#07c160" />
          <view class="contact-text">
            <text class="contact-label">微信号</text>
            <text class="contact-value selectable">{{customerService.wechatId}}</text>
          </view>
        </view>
      </view>
      <view class="contact-tip">
        <t-icon name="info-circle" size="28rpx" color="#0052d9" />
        <text class="tip-text">点击"复制微信号"按钮可快速复制到剪贴板</text>
      </view>
    </view>
  </t-dialog>

  <!-- Toast提示 -->
  <t-toast id="t-toast" />
</view>
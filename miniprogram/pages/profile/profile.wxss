.profile-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #0052d9, #1890ff);
  padding: 40rpx 30rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-container {
  position: relative;
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.edit-avatar-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.info-content {
  flex: 1;
}

.username-container {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
}

.edit-profile-btn {
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  transition: all 0.3s ease;
}

.edit-profile-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.95);
}

.user-id {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 功能菜单 */
.menu-section {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx;
}

/* 退出登录按钮 */
.logout-section {
  padding: 40rpx 30rpx;
  background: #fff;
}

/* 编辑个人信息弹窗 */
.edit-dialog {
  z-index: 9999;
}

.edit-form {
  padding: 30rpx 20rpx;
  min-height: 500rpx;
  background-color: #fff;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.form-item t-input,
.form-item t-textarea {
  width: 100%;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #fff;
  transition: border-color 0.3s ease;
}

.form-item t-input:focus,
.form-item t-textarea:focus {
  border-color: #0052d9;
  box-shadow: 0 0 0 2rpx rgba(0, 82, 217, 0.1);
}

.form-item.nickname t-input {
  font-weight: 500;
}

.form-item.phone t-input {
  letter-spacing: 1rpx;
}

.form-item.email t-input {
  font-family: monospace;
}

.form-item.bio t-textarea {
  min-height: 120rpx;
  line-height: 1.5;
}

.form-tip {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #f0f8ff;
  border-left: 4rpx solid #0052d9;
  border-radius: 4rpx;
}

.form-tip text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 消息通知弹窗 */
.notification-list {
  max-height: 60vh;
  overflow-y: auto;
}

.empty-notification {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.notification-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.notification-item:last-child {
  border-bottom: none;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.notification-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.notification-time {
  font-size: 24rpx;
  color: #999;
}

.notification-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 关于我们弹窗 */
.about-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.about-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.about-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.about-version {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.about-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.about-links {
  display: flex;
  align-items: center;
}

.link {
  font-size: 26rpx;
  color: #0052d9;
}

.link-divider {
  margin: 0 20rpx;
  color: #ddd;
}

/* TDesign组件样式覆盖 */
.t-cell-group__title {
  font-size: 28rpx;
  color: #999;
  padding: 24rpx 30rpx 12rpx;
}

.t-cell {
  padding: 24rpx 30rpx;
}

.t-cell__left-icon {
  margin-right: 20rpx;
}

.t-input,
.t-textarea {
  background: #f8f8f8;
  border-radius: 8rpx;
  border: none;
}

.t-dialog__content {
  max-height: 60vh;
  overflow-y: auto;
}

/* 联系客服弹窗样式 */
.contact-content {
  padding: 20rpx 0;
}

.contact-info {
  margin-bottom: 30rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-text {
  margin-left: 20rpx;
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.contact-value {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.contact-value.selectable {
  user-select: text;
  -webkit-user-select: text;
}

.contact-tip {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9ff;
  border-radius: 8rpx;
  border-left: 4rpx solid #0052d9;
}

.tip-text {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .user-card {
    padding: 30rpx 20rpx;
  }
  
  .avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .username {
    font-size: 32rpx;
  }
  
  .logout-section {
    padding: 30rpx 20rpx;
  }
  
  .contact-item {
    padding: 16rpx 0;
  }
  
  .contact-label {
    font-size: 26rpx;
  }
  
  .contact-value {
    font-size: 30rpx;
  }
  
  .tip-text {
    font-size: 24rpx;
  }
}